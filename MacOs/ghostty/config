## Setting up theme
#theme = light:rose-pine-dawn,dark:rose-pine
theme = Rose Pine

# font configuration
font-size = 16
font-family = "0x Proto Nerd Font"

## italics
font-family-italic = "caskaydiaCove Nerd Font"
window-title-font-family = "0x Proto Nerd Font"

alpha-blending = linear-corrected

macos-titlebar-style = tabs
macos-titlebar-proxy-icon = visible
#macos-titlebar-proxy-icon = hidden
#macos-option-as-alt = true

background = 000000
background-opacity = 0.90
background-blur-radius = 10

mouse-hide-while-typing = true

window-inherit-working-directory = false
working-directory = home

# keymaps
keybind = global:cmd+´=toggle_quick_terminal
#keybind = shift+ctrl+left_bracket=previous_tab
#keybind = shift+ctrl+right_bracket=next_tab
#keybind = shift+ctrl+physical:left=move_tab:0
#keybind = shift+ctrl+physical:right=move_tab:+1
keybind = ctrl+cmd+key_h=goto_split:left
keybind = ctrl+cmd+key_j=goto_split:down
keybind = ctrl+cmd+key_k=goto_split:up
keybind = ctrl+cmd+key_l=goto_split:right
keybind = ctrl+cmd+h=goto_split:left
keybind = ctrl+cmd+j=goto_split:down
keybind = ctrl+cmd+k=goto_split:up
keybind = ctrl+cmd+l=goto_split:right

#keybind = ctrl+cmd+one=goto_window:previous
#keybind = ctrl+cmd+zero=goto_window:next
keybind = ctrl+cmd+key_p=goto_window:previous
keybind = ctrl+cmd+key_o=goto_window:next
# shader
# custom-shader =
# custom-shader-animation = false

#window sizes
window-height = 20
window-width = 110

window-padding-x = 8
window-padding-y = 10

